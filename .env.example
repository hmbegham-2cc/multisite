# Supabase recommended local/Vercel format: use the IPv4-compatible pooler URL.
# Example:
# DATABASE_URI=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URI=postgres://payload:payload@localhost:5432/usine_a_site
PAYLOAD_SECRET=change-me-with-a-long-random-secret
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Optional: map local hostnames to site slugs (comma-separated host:slug)
DEV_SITE_HOSTS=fleuriste-martin.local:fleuriste-martin
# Optional: limit Postgres pool size (recommended with Supabase session pooler)
DATABASE_POOL_MAX=5
# Set to true only when you changed the schema and need auto-push (slow on startup)
PAYLOAD_DB_PUSH=false
# Do not set NODE_ENV here — Next.js le définit automatiquement (development / production / test).
