{
  "name": "usine-a-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development next dev --webpack",
    "build": "cross-env NODE_ENV=production next build",
    "start": "next start",
    "payload": "payload",
    "generate:importmap": "payload generate:importmap",
    "generate:types": "payload generate:types",
    "check:bookings": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/checkBookings.ts",
    "check:demo": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/checkDemoSite.ts",
    "seed:demo": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/createDemoSite.ts",
    "seed:publish-site": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/publishSiteContent.ts",
    "seed:superuser": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed/createSuperUser.ts",
    "migrate": "payload migrate",
    "migrate:create": "payload migrate:create",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@borewit/text-codec": "0.2.2",
    "@payloadcms/db-postgres": "3.85.1",
    "@payloadcms/next": "3.85.1",
    "@payloadcms/richtext-lexical": "3.85.1",
    "cross-env": "^7.0.3",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "payload": "3.85.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sharp": "^0.34.3",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "eslint": "^9.30.0",
    "eslint-config-next": "16.2.9",
    "patch-package": "^8.0.1",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}
